{
  "name": "@crypto-control/desktop",
  "version": "0.1.0",
  "description": "Crypto Control — gestión de cartera cripto con integración Coinbase",
  "author": "Emilio",
  "dependencies": {
    "@crypto-control/coinbase-sync": "*",
    "@crypto-control/core": "*",
    "@crypto-control/database": "*",
    "@crypto-control/market-data": "*",
    "7zip-bin": "^5.2.0"
  },
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "dev": "tsc && electron .",
    "rebuild-electron": "npx @electron/rebuild -f -w better-sqlite3",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dist:mac": "npm run build -w web && npm run build -w @crypto-control/desktop && npx @electron/rebuild -f -w better-sqlite3 --version 30.5.1 && electron-builder --mac --config.directories.output=dist-packaged"
  },
  "build": {
    "appId": "com.cryptocontrol.app",
    "productName": "Crypto Control",
    "directories": {
      "output": "dist-packaged"
    },
    "npmRebuild": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "icon": "../../assets/brand/logo.icns",

      "target": [
        "dmg"
      ],
      "category": "public.app-category.finance"
    },
    "extraResources": [
      {
        "from": "../../assets/brand/logo.png",
        "to": "assets/brand/logo.png"
      },
      {
        "from": "../web/dist",
        "to": "web/dist"
      },
      {
        "from": "../../packages/database/drizzle",
        "to": "migrations"
      },
      {
        "from": "bin/keychain-helper",
        "to": "bin/keychain-helper"
      }
    ],
    "dmg": {
      "title": "Crypto Control"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "electron": "30.5.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5"
  }
}
