{
  "name": "@crypto-control/desktop",
  "version": "0.1.0",
  "dependencies": {
    "@crypto-control/coinbase-sync": "*",
    "@crypto-control/core": "*",
    "@crypto-control/database": "*",
    "@crypto-control/market-data": "*",
    "7zip-bin": "^5.2.0"
  },
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "dev": "tsc && electron .",
    "rebuild-electron": "npx @electron/rebuild -f -w better-sqlite3",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "build": {
    "appId": "com.cryptocontrol.app",
    "productName": "Crypto Control",
    "directories": {
      "output": "dist-packaged"
    },
    "mac": {
      "icon": "../../assets/brand/logo-1024.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.finance"
    },
    "extraResources": [
      {
        "from": "../../assets/brand/logo.png",
        "to": "assets/brand/logo.png"
      },
      {
        "from": "../web/dist",
        "to": "web/dist"
      },
      {
        "from": "../../packages/database/drizzle",
        "to": "migrations"
      }
    ],
    "dmg": {
      "title": "Crypto Control"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5"
  }
}
